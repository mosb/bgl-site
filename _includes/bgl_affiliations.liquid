<div class="bgl-affiliations">
  <a class="bgl-affiliation-mark"
     href="https://aigi.ox.ac.uk/" target="_blank" rel="noopener"
     aria-label="Oxford Martin AI Governance Initiative, University of Oxford">
    <img class="bgl-affiliation-logo bgl-affiliation-logo--light"
         src="{{ '/assets/img/aigi-oxford-lockup-light.png' | relative_url }}"
         alt="Oxford Martin AI Governance Initiative, University of Oxford"
         loading="lazy">
    <img class="bgl-affiliation-logo bgl-affiliation-logo--dark"
         src="{{ '/assets/img/aigi-oxford-lockup-dark.png' | relative_url }}"
         alt="Oxford Martin AI Governance Initiative, University of Oxford"
         loading="lazy">
  </a>
</div>
<script>
(function () {
  function place() {
    var mark = document.querySelector('.bgl-affiliations');
    if (!mark) return;
    var header = document.querySelector('.post-header');
    var title = header && header.querySelector('.post-title');
    if (header && title && !header.contains(mark)) {
      var col = document.createElement('div');
      col.className = 'bgl-header-text';
      header.insertBefore(col, title);
      col.appendChild(title);
      var desc = header.querySelector('.desc, .post-description') ||
                 header.querySelector(':scope > p');
      if (desc) col.appendChild(desc);
      header.appendChild(mark);
      header.classList.add('bgl-header-flex');
    } else {
      mark.classList.add('bgl-affil-fallback');
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', place);
  } else { place(); }
})();
</script>
